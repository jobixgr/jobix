# Αντίγραψε αυτό το αρχείο σε ".env" και συμπλήρωσε τις τιμές σου.
# (Το .env ΔΕΝ ανεβαίνει σε git — περιέχει μυστικά.)
# Στο Vercel, τα ίδια μπαίνουν στο Settings → Environment Variables.

# ============ ΥΠΟΧΡΕΩΤΙΚΑ ============

# --- Supabase (βάση + storage) ---
# Από: Supabase → Project Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
# ΠΡΟΣΟΧΗ: το service_role key (ΟΧΙ το anon). Είναι μυστικό — μόνο server-side.
SUPABASE_SERVICE_ROLE=eyJhbGciOi...
SUPABASE_BUCKET=jobix-uploads

# --- Ασφάλεια ---
# Τουλάχιστον 32 χαρακτήρες, τυχαίο. Δημιουργία: openssl rand -hex 32
# ΑΝ ΑΛΛΑΞΕΙ, αποσυνδέονται όλοι οι χρήστες.
JWT_SECRET=βαλε_εδω_τυχαια_συμβολοσειρα_τουλαχιστον_32_χαρακτηρων

# Τα domains που επιτρέπονται να καλούν το API (comma-separated, χωρίς κενά).
# Το ΠΡΩΤΟ χρησιμοποιείται και ως βάση για τα links στα email.
ALLOWED_ORIGINS=https://jobix.gr,https://www.jobix.gr

# --- Email (Resend) ---
# Το API key από το resend.com (ξεκινά με re_...)
RESEND_API_KEY=re_βαλε_εδω_το_key_σου
# Ο αποστολέας. Το domain πρέπει να είναι verified στο Resend.
EMAIL_FROM=Jobix <offers@jobix.gr>

# ============ ΠΡΟΑΙΡΕΤΙΚΑ ============

# Η κανονική διεύθυνση της εφαρμογής. Χρησιμοποιείται για ΟΛΑ τα links
# που στέλνονται με email (reset password, verify email, δημόσιες προσφορές).
# ΑΣΦΑΛΕΙΑ: αν λείπει, χρησιμοποιείται το πρώτο του ALLOWED_ORIGINS.
# Ποτέ δεν παίρνεται από το request του χρήστη (προστασία από phishing).
# APP_URL=https://jobix.gr

# --- Google Sign-In ---
# Από: console.cloud.google.com → APIs & Services → Credentials
# Το ίδιο Client ID και στα δύο (το VITE_ το βλέπει το frontend).
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# --- AI δημιουργία προσφορών ---
# Αν λείπει, όλα δουλεύουν εκτός από το AI.
# ANTHROPIC_API_KEY=sk-ant-...
