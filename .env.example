# Αντίγραψε αυτό το αρχείο σε ".env" και συμπλήρωσε τις τιμές σου.
# (Το .env ΔΕΝ ανεβαίνει σε git — περιέχει μυστικά.)

# --- Email (Resend) ---
# Το API key από το resend.com  (ξεκινά με re_...)
RESEND_API_KEY=re_βαλε_εδω_το_key_σου
# Ο αποστολέας των email. Το domain πρέπει να είναι verified στο Resend.
EMAIL_FROM=Jobix <offers@jobix.gr>

# --- AI δημιουργία προσφορών (προαιρετικό) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Άλλα (προαιρετικά) ---
# PORT=4000
# JWT_SECRET=  (αν λείπει, δημιουργείται αυτόματα)
